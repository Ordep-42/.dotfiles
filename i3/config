# include keybindings
include "keybinds.conf"

# include workspace settings
include "workspaces.conf"

# include dracula theme config
include "dracula.conf"

# include i3bar config
include "bar.conf"

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango:monospace 11

# Start XDG autostart .desktop files using dex.
exec --no-startup-id dex --autostart --environment i3

# xss-lock grabs a logind suspend inhibit lock and will use i3lock to lock the
# screen before suspend. Use loginctl lock-session to lock your screen.
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork

# Start dunst (notifications)
exec_always dunst -conf ~/.config/dunst/dunstrc

# thunar daemon mode
exec_always thunar --daemon

# Set keyboard layout after login
exec_always setxkbmap br

# Use picom as compositor
exec_always --no-startup-id picom -f --config ~/.config/picom/picom.conf

# Display wallpapers
exec_always --no-startup-id feh --bg-fill --randomize ~/Imagens/wallpapers/*

# Start network bar update script
exec_always --no-startup-id ~/.scripts/network_update

# Remove title bar
default_border pixel 3

# include gaps config
include "gaps.conf"

#for_window [class=".*"] split toggle

# clipboard
exec 'greenclip daemon>/dev/null'
