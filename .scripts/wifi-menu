#!/bin/bash

notify-send "Escaneando redes Wi-Fi disponГ­veis..."
# Get a list of available wifi connections and morph it into a nice-looking list
wifi_list=$(nmcli --fields "SECURITY,SSID" device wifi list | sed 1d | sed 's/  */ /g' | sed -E "s/WPA*.?\S/пЂЈ /g" | sed "s/^--/п‚њ /g" | sed "s/пЂЈ  пЂЈ/пЂЈ/g" | sed "/--/d")

connected=$(nmcli -fields WIFI g)
if [[ "$connected" =~ "habilitado" ]]; then
	toggle="п€„ Desativar Wi-Fi"
elif [[ "$connected" =~ "desabilitado" ]]; then
	toggle="п‡« Ativar Wi-Fi"
fi

# Use rofi to select wifi network
chosen_network=$(echo -e "$toggle\n$wifi_list" | uniq -u | rofi -dmenu -i -selected-row 1 -p "Wi-Fi: " )
# Get name of connection
read -r chosen_id <<< "${chosen_network:3}"

if [ "$chosen_network" = "" ]; then
	exit
elif [ "$chosen_network" = "п‡« Ativar Wi-Fi" ]; then
	nmcli radio wifi on
elif [ "$chosen_network" = "п€„ Desativar Wi-Fi" ]; then
	nmcli radio wifi off
else
	# Message to show when connection is activated successfully
  	success_message="Conectado a \"$chosen_id\"."
	# Get saved connections
	saved_connections=$(nmcli -g NAME connection)
	if [[ $(echo "$saved_connections" | grep -w "$chosen_id") = "$chosen_id" ]]; then
		nmcli connection up id "$chosen_id" | grep "sucesso" && notify-send "ConexГЈo estabelecida" "$success_message"
	else
		if [[ "$chosen_network" =~ "пЂЈ" ]]; then
			wifi_password=$(rofi -dmenu -password -p "Digite a senha: " )
		fi
		nmcli device wifi connect "$chosen_id" password "$wifi_password" | grep "successfully" && notify-send "ConexГЈo estabelecida" "$success_message"
    fi
fi
