#!/bin/bash

VOLUME=$(pactl get-sink-volume @DEFAULT_SINK@ | awk '{ print $5 }' | rev | cut -c 2-3 | rev)
MUTE=$(pactl get-sink-mute @DEFAULT_SINK@ | awk '{ print $2 }')
ICON=""

if [[ $MUTE == 'no' ]]; then
	if [[ $VOLUME -lt 5 ]]; then
		ICON="´ÇŽ "
	elif [[ $VOLUME -le 30 ]]; then
		ICON="´Çž "
	else
		ICON="´ÇĘ "
	fi
else 
	ICON="´Üę "
fi

printf "%s %s%%\n%s " $ICON $VOLUME $ICON
