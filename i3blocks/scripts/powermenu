#!/bin/bash

choice=$(printf "пЂ‘ Power off\nп‹№ Restart\nпЉ‹ Suspend\nпЂЈ Lock" | rofi -dmenu -i -theme-str "@import 'power.rasi'")

case "$choice" in
	"пЂ‘ Power off") poweroff ;;
	"п‹№ Restart") reboot ;;
	"пЉ‹ Suspend") systemctl suspend-then-hibernate ;;
	"пЂЈ Lock") i3lock ;;
	*) exit 1;;
esac
